# Enterprise AI Copilot - Environment Variables
# Copy this file to .env and fill in your values

# === LLM Configuration ===
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here  # Uncomment if using OpenAI

# LLM Provider: "groq" or "openai"
LLM_PROVIDER=groq

# Model name (Groq: llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.)
# Model name (OpenAI: gpt-4o, gpt-4o-mini, etc.)
LLM_MODEL=llama-3.3-70b-versatile

# === Embeddings ===
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# === Authentication ===
JWT_SECRET=change_this_to_a_strong_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# === Application ===
APP_NAME=Enterprise AI Copilot
MAX_UPLOAD_SIZE_MB=50
DEFAULT_TEMPERATURE=0.3
DEFAULT_MAX_TOKENS=2048
